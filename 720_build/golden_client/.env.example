# Plantilla de configuración del Postgres local del golden client (COMMITEADA).
# Copiar a `.env` (gitignored) y ajustar. NO poner secretos reales aquí.
#
#   cp .env.example .env
#
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esto
POSTGRES_DB=foda
# Puerto host (5432 suele estar ocupado). El contenedor siempre expone 5432 adentro.
HOST_PORT=55432
